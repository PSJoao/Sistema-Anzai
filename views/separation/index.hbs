<div class="page-header">
    <div>
        <h1>Separação de Produtos</h1>
        <p>Utilize os filtros abaixo para organizar sua fila de trabalho.</p>
    </div>
</div>

<div class="card mb-4" style="margin-bottom: 20px; ">
    <div class="card-body">
        <form id="separationFiltersForm" method="GET" action="/separacao" style="display: flex; gap: 50px; align-items: center; flex-wrap: wrap;">
            
            <div class="form-group mb-0">
                <label for="companySelect" style="font-weight: bold; display: block; margin-bottom: 5px;">Filtrar Loja:</label>
                <select name="company" id="companySelect" class="form-control" style="min-width: 150px;">
                    <option value="todos" {{#if (eq activeCompany 'todos')}}selected{{/if}}>Todas as Lojas</option>
                    {{#each companies}}
                        <option value="{{this}}" {{#if (eq ../activeCompany this)}}selected{{/if}}>Loja {{this}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="form-group mb-0">
                <label style="font-weight: bold; display: block; margin-bottom: 5px;">Filtrar por prazo: </label>
                <div style="display: flex; gap: 15px; align-items: center; height: 38px;">
                    <label style="cursor: pointer; display: flex; align-items: center; gap: 6px; margin: 0;">
                        <input type="checkbox" name="deadlines" value="atrasado" {{#if (includes activeDeadlines 'atrasado')}}checked{{/if}}>
                        <span class="text-primary font-weight-bold">Atrasados</span>
                    </label>
                    
                    <label style="cursor: pointer; display: flex; align-items: center; gap: 6px; margin: 0;">
                        <input type="checkbox" name="deadlines" value="hoje" {{#if (includes activeDeadlines 'hoje')}}checked{{/if}}>
                        <span class="text-primary font-weight-bold">Para Hoje</span>
                    </label>
                    
                    <label style="cursor: pointer; display: flex; align-items: center; gap: 6px; margin: 0;">
                        <input type="checkbox" name="deadlines" value="futuro" {{#if (includes activeDeadlines 'futuro')}}checked{{/if}}>
                        <span class="text-muted">Futuros</span>
                    </label>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">
                Aplicar Filtros
            </button>
        </form>
    </div>
</div>

{{#if error}}
    <div class="card mb-4">
        <div class="card-body">
            <div class="form-error text-danger">{{error}}</div>
        </div>
    </div>
{{/if}}

{{#if departments.length}}
    <div class="separation-department-grid">
        {{#each departments}}
            <article class="card separation-department-card">
                <div class="card-header" style="display: flex; flex-direction: column; gap: 8px;">
                    <h3 style="margin: 0;">{{lookup ../departmentLabels this.cod_departamento}}</h3>
                    
                    {{!-- Renderização Condicional das Flags de Plataforma --}}
                    {{#if this.plataformas}}
                        <div class="platform-flags" style="display: flex; gap: 6px; flex-wrap: wrap;">
                            {{#each this.plataformas}}
                                {{#if (eq @key 'mercado_livre')}}
                                    <span class="badge" style="background-color: #FFE600; color: #333; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; border: 1px solid rgba(0,0,0,0.1);">ML</span>
                                {{else if (eq @key 'shopee')}}
                                    <span class="badge" style="background-color: #EE4D2D; color: #FFF; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; border: 1px solid rgba(0,0,0,0.1);">Shopee</span>
                                {{else}}
                                    {{!-- Fallback para futuras plataformas --}}
                                    <span class="badge" style="background-color: #8E44AD; color: #FFF; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; text-transform: capitalize;">{{@key}}</span>
                                {{/if}}
                            {{/each}}
                        </div>
                    {{/if}}
                </div>
                
                <div class="card-body">
                    <div class="stat-row" style="margin-bottom: 10px;">
                        <div class="text-muted small">Produtos Pendentes: {{this.produtos_com_pendencia}}</div>
                        <div class="text-muted small">Unidades Pendentes: {{this.unidades_pendentes}}</div>
                    </div>

                    {{#if this.plataformas}}
                        <div class="department-stats" style="margin-top: 15px; font-size: 0.9rem;">
                            <strong style="display: block; margin-bottom: 10px; color: #555;">Pendências por Plataforma:</strong>
                            
                            {{#each this.plataformas}}
                                <div style="margin-bottom: 8px; padding: 8px 12px; background-color: #f8f9fa; border-radius: 6px; border-left: 4px solid {{#if (eq @key 'mercado_livre')}}#FFE600{{else if (eq @key 'shopee')}}#EE4D2D{{else}}#8E44AD{{/if}};">
                                    
                                    {{!-- Título da Plataforma --}}
                                    <strong style="display: block; margin-bottom: 5px; color: #333; text-transform: capitalize;">
                                        {{#if (eq @key 'mercado_livre')}}Mercado Livre{{else}}{{@key}}{{/if}}
                                    </strong>
                                    
                                    {{!-- Lista de Lojas dentro desta Plataforma --}}
                                    <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px;">
                                        {{#each this}}
                                            <li style="display: flex; justify-content: space-between; border-bottom: 1px dashed #ddd; padding-bottom: 2px;">
                                                <span>Loja {{@key}}</span>
                                                <strong>Un. Pend.: {{this}}</strong>
                                            </li>
                                        {{/each}}
                                    </ul>
                                </div>
                            {{/each}}
                            
                        </div>
                    {{/if}}
                </div>
                
                <footer class="card-footer" style="margin-top: 10px; text-align: center;">
                    <a href="/separacao/departamento/{{this.cod_departamento}}" 
                       class="btn btn-primary btn-block btn-department-link">
                       Iniciar Separação
                    </a>
                </footer>
            </article>
        {{/each}}
    </div>
{{else}}
    <div class="empty-state card">
        <div class="card-body text-center py-5">
            <p class="text-muted lead">Nenhum departamento possui produtos pendentes com os filtros selecionados.</p>
            <a href="/separacao" class="btn btn-outline mt-3">Ver Tudo</a>
        </div>
    </div>
{{/if}}

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Pega os parâmetros da URL atual (ex: ?company=001&deadlines=atrasado)
        const currentParams = window.location.search;
        
        if (currentParams) {
            const links = document.querySelectorAll('.btn-department-link');
            links.forEach(link => {
                // Anexa os parâmetros ao link existente
                link.href += currentParams;
            });
        }
    });
</script>